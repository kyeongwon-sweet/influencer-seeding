# -----------------------------------------------
# 인플루언서 시딩 시스템 환경변수 템플릿
# -----------------------------------------------
# 이 파일을 복사해서 .env 파일을 만들고 실제 값을 입력하세요.
# .env 파일은 절대 GitHub에 올리지 마세요. (이미 .gitignore에 등록됨)
# -----------------------------------------------

# Apify (인스타그램/유튜브 데이터 수집)
APIFY_API_TOKEN=

# Supabase (데이터베이스)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# GitHub Actions 트리거 (웹앱 → Actions)
GITHUB_TOKEN=
GITHUB_REPO=your-github-username/your-repo-name
